{
  "_comment": "验收标准 Mock 数据 —— 制药行业分析方法验收标准",
  "version": "2024-Q1",
  "standards": [
    {
      "id": "AC-HPLC-001",
      "名称": "含量测定（HPLC法）验收标准",
      "适用范围": "原料药及制剂含量测定",
      "验收项目": [
        {
          "项目": "含量",
          "接受标准": "标示量的98.0%~102.0%",
          "判断依据": "单次测定结果",
          "参考依据": "ICH Q2(R1)"
        },
        {
          "项目": "精密度（RSD）",
          "接受标准": "≤ 2.0%",
          "判断依据": "6次平行测定",
          "参考依据": "ICH Q2(R1)"
        },
        {
          "项目": "系统适用性（理论板数）",
          "接受标准": "≥ 2000",
          "判断依据": "主峰计算",
          "参考依据": "中国药典2020版"
        },
        {
          "项目": "系统适用性（拖尾因子）",
          "接受标准": "0.8~1.5",
          "判断依据": "主峰计算",
          "参考依据": "中国药典2020版"
        },
        {
          "项目": "回收率",
          "接受标准": "98.0%~102.0%",
          "判断依据": "加标回收实验（低、中、高三个浓度）",
          "参考依据": "ICH Q2(R1)"
        },
        {
          "项目": "线性范围",
          "接受标准": "R² ≥ 0.999",
          "判断依据": "5个浓度点线性回归",
          "参考依据": "ICH Q2(R1)"
        }
      ]
    },
    {
      "id": "AC-UV-001",
      "名称": "含量测定（UV法）验收标准",
      "适用范围": "具有紫外吸收的原料药及制剂",
      "验收项目": [
        {
          "项目": "含量",
          "接受标准": "标示量的98.0%~102.0%",
          "判断依据": "与对照品比较法"
        },
        {
          "项目": "精密度（RSD）",
          "接受标准": "≤ 1.0%",
          "判断依据": "6次重复测定吸光度"
        },
        {
          "项目": "线性",
          "接受标准": "R² ≥ 0.999，截距不超过最低浓度对应吸光度的5%",
          "判断依据": "5个以上浓度点"
        }
      ]
    },
    {
      "id": "AC-DISS-001",
      "名称": "溶出度验收标准",
      "适用范围": "口服固体制剂（片剂、胶囊）",
      "验收项目": [
        {
          "项目": "溶出量（第一阶段 S1）",
          "接受标准": "6片中每片溶出量 ≥ Q+5%（通常Q=80%）",
          "时间点": "按品种规定时间点",
          "参考依据": "中国药典2020版四部通则0931"
        },
        {
          "项目": "溶出量（第二阶段 S2）",
          "接受标准": "12片平均溶出量≥Q，且每片≥Q-15%，最多1片<Q-15%",
          "参考依据": "中国药典2020版四部通则0931"
        },
        {
          "项目": "RSD",
          "接受标准": "≤ 20%（早期溶出），≤ 10%（平台期）",
          "参考依据": "ICH Q2(R1)"
        }
      ]
    },
    {
      "id": "AC-STERILE-001",
      "名称": "无菌检查验收标准",
      "适用范围": "注射剂、眼用制剂等无菌制品",
      "验收项目": [
        {
          "项目": "无菌性",
          "接受标准": "培养14天后，硫乙醇酸盐培养基和胰酪大豆胨培养基均无菌生长",
          "参考依据": "中国药典2020版附录无菌检查法"
        },
        {
          "项目": "培养基灵敏度",
          "接受标准": "阳性对照菌生长良好（+），阴性对照无菌生长（-）",
          "参考依据": "中国药典2020版"
        }
      ]
    },
    {
      "id": "AC-PH-001",
      "名称": "pH值验收标准",
      "适用范围": "注射液、口服液等液体制剂",
      "验收项目": [
        {
          "项目": "pH准确度",
          "接受标准": "pH计示值与标准缓冲液标定值偏差 ≤ 0.02 pH单位",
          "参考依据": "中国药典2020版四部通则0631"
        },
        {
          "项目": "重复性",
          "接受标准": "同一样品连续测定3次，极差 ≤ 0.1 pH单位",
          "参考依据": "中国药典2020版"
        }
      ]
    },
    {
      "id": "AC-METHOD-VAL-001",
      "名称": "分析方法验证通用验收标准",
      "适用范围": "所有定量分析方法",
      "验收项目": [
        {
          "项目": "专属性",
          "接受标准": "空白干扰 < 0.1%，各杂质峰与主峰分离度 ≥ 1.5",
          "参考依据": "ICH Q2(R1)"
        },
        {
          "项目": "检测限（LOD）",
          "接受标准": "信噪比 ≥ 3:1",
          "参考依据": "ICH Q2(R1)"
        },
        {
          "项目": "定量限（LOQ）",
          "接受标准": "信噪比 ≥ 10:1，精密度 ≤ 10%，准确度 80%~120%",
          "参考依据": "ICH Q2(R1)"
        },
        {
          "项目": "溶液稳定性",
          "接受标准": "供试品溶液在规定时间内，与新鲜配制溶液比较，峰面积偏差 ≤ 2%",
          "参考依据": "常规要求"
        },
        {
          "项目": "中间精密度",
          "接受标准": "不同操作人员、不同天次测定RSD ≤ 2.0%",
          "参考依据": "ICH Q2(R1)"
        }
      ]
    }
  ]
}
